# --- URLs publiques ---
NEXT_PUBLIC_SITE_URL=https://ansetassurances.com
NEXT_PUBLIC_SOUSCRIPTION_BASE_URL=https://souscription.ansetassurances.com
NEXT_PUBLIC_ESPACE_CLIENT_URL=https://espace.ansetassurances.com

# --- Emailing (Brevo) ---
# Clé API Brevo (transactionnel)
BREVO_API_KEY=
# Expéditeur : doit être un sender VÉRIFIÉ dans Brevo (actuellement : contact@coverseas.fr)
BREVO_FROM_EMAIL=contact@coverseas.fr
BREVO_FROM_NAME=ANSET Assurances

# --- Destinataires des formulaires ---
# Boîte de réception des demandes (contact + résiliation)
ANSET_CONTACT_TO=hello@ansetassurances.com
ANSET_RESILIATION_TO=hello@ansetassurances.com
# Copie (CC) optionnelle des déclarations de sinistre ; laisser vide pour aucune copie
ANSET_SINISTRE_CC=

# --- Chatbot Poe (Anthropic) ---
ANTHROPIC_API_KEY=
# Modèle utilisé par le chatbot (défaut : claude-haiku-4-5)
ANSET_CHATBOT_MODEL=claude-haiku-4-5

# --- Trustpilot (Automatic Feedback Service) ---
# Clé d'intégration Trustpilot ; tant qu'elle est vide, le script n'est pas chargé
NEXT_PUBLIC_TRUSTPILOT_KEY=
# ID de template d'invitation Trustpilot (optionnel ; sinon template par défaut)
NEXT_PUBLIC_TRUSTPILOT_TEMPLATE_ID=
